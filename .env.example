# =============================================================================
# Discipline OS — environment variables reference
# Copy to .env and fill in real values. NEVER commit .env to git.
# See Docs/Technicals/01_Tech_Stack.md and 14_Authentication_Logging.md
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# For local dev, matches docker-compose.yml postgres service.
# For prod, use the RDS Multi-AZ endpoint via Secrets Manager.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://discipline:devpassword@localhost:5432/discipline_dev

# Timescale / analytics DB (separate RDS instance in prod — same local for dev)
TIMESCALE_URL=postgresql+asyncpg://discipline:devpassword@localhost:5432/discipline_dev

# -----------------------------------------------------------------------------
# Redis
# For local dev, matches docker-compose.yml redis service.
# Prefix /0 = default database; use /1 for Celery broker if desired.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# Clerk (identity provider)
# Get from https://dashboard.clerk.com → API Keys
# -----------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# -----------------------------------------------------------------------------
# Session JWT (EdDSA / Ed25519 via AWS KMS in prod; HS256 secret acceptable in dev)
# AUDIT_CHAIN_SECRET must never be the same between environments.
# -----------------------------------------------------------------------------
SESSION_JWT_SECRET=dev-session-jwt-secret-change-in-prod
AUDIT_CHAIN_SECRET=dev-audit-chain-secret-change-in-prod

# -----------------------------------------------------------------------------
# Anthropic / Claude API
# Routing: Haiku 4.5 (high-volume), Sonnet 4.6 (reflection), Opus 4.7 (rare)
# NEVER used on T3/T4 crisis paths.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# -----------------------------------------------------------------------------
# AWS — use LocalStack for local dev (docker-compose.yml localstack service)
# In prod, use IRSA / ECS task role instead of long-lived keys.
# -----------------------------------------------------------------------------
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# S3 buckets (LocalStack creates these on first use; provisioning script in
# services/api/scripts/localstack_init.sh)
S3_VOICE_BUCKET=discipline-voice-blobs
S3_EXPORTS_BUCKET=discipline-exports
S3_ASSETS_BUCKET=discipline-assets
S3_ML_ARTIFACTS_BUCKET=discipline-ml-artifacts

# Voice blob hard-delete: 72h enforced by S3 lifecycle + worker (see Rule 7)
VOICE_BLOB_RETENTION_HOURS=72

# -----------------------------------------------------------------------------
# Stripe (payments)
# Test keys safe to use locally; never commit live keys.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET_HERE

# -----------------------------------------------------------------------------
# Email (local dev → MailHog; prod → Postmark/Resend)
# MailHog web UI: http://localhost:8025
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@disciplineos.local

# -----------------------------------------------------------------------------
# OpenTelemetry
# Leave OTEL_EXPORTER_OTLP_ENDPOINT empty to disable tracing in dev.
# Set to http://localhost:4318 if running a local Grafana/Tempo stack.
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=discipline-api

# -----------------------------------------------------------------------------
# PostHog (self-hosted analytics)
# Safe to leave blank in dev; events will be silently dropped.
# -----------------------------------------------------------------------------
POSTHOG_API_KEY=
POSTHOG_HOST=https://posthog.disciplineos.internal

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_VERSION=dev
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Allowed CORS origins for the API (comma-separated)
ALLOWED_ORIGINS=http://localhost:3010,http://localhost:3020,http://localhost:3030,http://localhost:3040,http://localhost:3050

# Feature flag service (Unleash self-hosted or ConfigCat)
UNLEASH_URL=
UNLEASH_API_KEY=
