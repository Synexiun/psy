{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource (Amazon Managed Prometheus or self-hosted)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Crisis path SLO dashboard — shown during on-call reviews to verify T3 clinical SLO (p99 ≤ 200 ms, error rate = 0). Covers /v1/sos and /v1/crisis/resources. 100% trace sampling on these endpoints. Any SLO breach is a P0.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["disciplineos"],
      "targetBlank": true,
      "title": "API Overview",
      "tooltip": "Full Discipline OS API dashboard",
      "type": "dashboards",
      "url": "/d/discipline-api-overview/discipline-os-api"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "SLO Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Current p99 latency on /v1/sos over the last 5 minutes. SLO: ≤ 200 ms. Green < 150 ms, yellow 150–200 ms, red > 200 ms (SLO breach). Any red reading is a P0 page — do not wait.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.15 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99,\n  sum by (le) (\n    rate(http_server_request_duration_seconds_bucket{\n      job=~\"$job\",\n      url_path=\"/v1/sos\"\n    }[5m])\n  )\n)",
          "hide": false,
          "legendFormat": "SOS p99",
          "refId": "A"
        }
      ],
      "title": "SOS p99 Latency (SLO: ≤ 200 ms)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Current p99 latency on /v1/crisis/resources over the last 5 minutes. SLO: ≤ 200 ms. This endpoint delivers hotline numbers and static safety resources; it must be fast and always available.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.15 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99,\n  sum by (le) (\n    rate(http_server_request_duration_seconds_bucket{\n      job=~\"$job\",\n      url_path=\"/v1/crisis/resources\"\n    }[5m])\n  )\n)",
          "hide": false,
          "legendFormat": "crisis/resources p99",
          "refId": "A"
        }
      ],
      "title": "Crisis Resources p99 Latency (SLO: ≤ 200 ms)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "5xx error rate on crisis endpoints. This MUST be 0 at all times. Any non-zero value is a P0 breach. Note: the static web-crisis surface (crisis.disciplineos.com) is a separate S3/CloudFront deployment and is not measured here — it has its own 99.99% SLO via CloudFront metrics.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": { "0": { "color": "green", "index": 0, "text": "0 — OK" } },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.0001 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(\n  rate(http_server_request_duration_seconds_count{\n    job=~\"$job\",\n    url_path=~\"/v1/sos|/v1/crisis/resources\",\n    http_response_status_code=~\"5..\"\n  }[5m])\n)\n/\nsum(\n  rate(http_server_request_duration_seconds_count{\n    job=~\"$job\",\n    url_path=~\"/v1/sos|/v1/crisis/resources\"\n  }[5m])\n)",
          "hide": false,
          "legendFormat": "crisis 5xx rate",
          "refId": "A"
        }
      ],
      "title": "Crisis Path Error Rate (must be 0)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "SOS submissions per hour. A sudden drop may indicate a client-side regression blocking crisis access. An unexpected spike warrants clinical operations awareness.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(\n  increase(http_server_request_duration_seconds_count{\n    job=~\"$job\",\n    url_path=\"/v1/sos\",\n    http_request_method=\"POST\"\n  }[1h])\n)",
          "hide": false,
          "legendFormat": "SOS submissions / hr",
          "refId": "A"
        }
      ],
      "title": "SOS Submissions per Hour",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "Crisis Path Latency Time Series",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p99 latency over time for /v1/sos and /v1/crisis/resources with a hard red threshold at 200 ms. This is the primary chart reviewed during on-call handoff and incident post-mortems. The dashed red line at 0.2 s represents the T3 clinical SLO. SLO burn-rate: 14.4x 1-hour window = P0 page; 6x 6-hour window = P1 page.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "latency",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "rgba(242, 73, 92, 0.1)", "value": 0.2 }
            ]
          },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SOS p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "SOS p95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "SOS p50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "crisis/resources p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "SLO 200 ms" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "p99"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50,\n  sum by (le) (\n    rate(http_server_request_duration_seconds_bucket{\n      job=~\"$job\",\n      url_path=\"/v1/sos\"\n    }[5m])\n  )\n)",
          "hide": false,
          "legendFormat": "SOS p50",
          "range": true,
          "refId": "SOS_P50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95,\n  sum by (le) (\n    rate(http_server_request_duration_seconds_bucket{\n      job=~\"$job\",\n      url_path=\"/v1/sos\"\n    }[5m])\n  )\n)",
          "hide": false,
          "legendFormat": "SOS p95",
          "range": true,
          "refId": "SOS_P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99,\n  sum by (le) (\n    rate(http_server_request_duration_seconds_bucket{\n      job=~\"$job\",\n      url_path=\"/v1/sos\"\n    }[5m])\n  )\n)",
          "hide": false,
          "legendFormat": "SOS p99",
          "range": true,
          "refId": "SOS_P99"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99,\n  sum by (le) (\n    rate(http_server_request_duration_seconds_bucket{\n      job=~\"$job\",\n      url_path=\"/v1/crisis/resources\"\n    }[5m])\n  )\n)",
          "hide": false,
          "legendFormat": "crisis/resources p99",
          "range": true,
          "refId": "CRISIS_P99"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "vector(0.2)",
          "hide": false,
          "legendFormat": "SLO 200 ms",
          "range": true,
          "refId": "SLO"
        }
      ],
      "title": "Crisis Path Latency vs 200 ms SLO (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Crisis Path Request Volume",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Request rate on /v1/sos and /v1/crisis/resources split by HTTP status. Any 5xx bars here represent a P0 incident. 4xx on /v1/sos likely indicates a client auth issue — check Clerk session health.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "req/s",
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "reqps"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*5.." },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*4.." },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 6,
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum by (url_path, http_response_status_code) (\n  rate(http_server_request_duration_seconds_count{\n    job=~\"$job\",\n    url_path=~\"/v1/sos|/v1/crisis/resources\"\n  }[5m])\n)",
          "hide": false,
          "legendFormat": "{{url_path}} {{http_response_status_code}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Crisis Path Request Rate by Endpoint + Status",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "5xx error rate on crisis endpoints over time. This line should be flat at zero. Any deviation from zero is a critical incident. The Y-axis starts at 0 and the threshold zone turns red at any non-zero value.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "error rate",
            "axisCenteredZero": false,
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "area" }
          },
          "mappings": [],
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 0.0001 }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 7,
      "options": {
        "legend": {
          "calcs": ["max"],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "sum(\n  rate(http_server_request_duration_seconds_count{\n    job=~\"$job\",\n    url_path=~\"/v1/sos|/v1/crisis/resources\",\n    http_response_status_code=~\"5..\"\n  }[5m])\n)\n/\nsum(\n  rate(http_server_request_duration_seconds_count{\n    job=~\"$job\",\n    url_path=~\"/v1/sos|/v1/crisis/resources\"\n  }[5m])\n)",
          "hide": false,
          "legendFormat": "5xx error rate",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Crisis Path Error Rate (should always be 0)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["disciplineos", "crisis", "slo", "t3", "clinical"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(http_server_request_duration_seconds_count, job)",
        "hide": 0,
        "includeAll": false,
        "label": "API Job",
        "multi": false,
        "name": "job",
        "options": [],
        "query": {
          "query": "label_values(http_server_request_duration_seconds_count, job)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Discipline OS — Crisis Path SLO",
  "uid": "discipline-crisis-path",
  "version": 1,
  "weekStart": ""
}
