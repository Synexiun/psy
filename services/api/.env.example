# Runtime
DISCIPLINE_ENV=dev
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://discipline:discipline@localhost:5432/discipline
TIMESCALE_URL=postgresql+asyncpg://discipline:discipline@localhost:5433/discipline_ts

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 (localstack in dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
S3_VOICE_BUCKET=disciplineos-dev-voice
S3_EXPORT_BUCKET=disciplineos-dev-exports

# KMS
KMS_KEY_ID=alias/discipline-dev
KMS_ENDPOINT_URL=http://localhost:4566

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev
SERVER_SESSION_SECRET=dev-secret-replace-me

# Anthropic
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Push
APNS_KEY_PATH=secrets/apns.p8
APNS_KEY_ID=replace
APNS_TEAM_ID=replace
FCM_CREDENTIALS_PATH=secrets/fcm.json

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=discipline-api
