    "./primitives/Select": "./src/primitives/Select.tsx",
    "./primitives/TabNav": "./src/primitives/TabNav.tsx",
    "./primitives/Dialog": "./src/primitives/Dialog.tsx",
    "./primitives/Sheet": "./src/primitives/Sheet.tsx",
    "./primitives/Toast": "./src/primitives/Toast.tsx",
    "./primitives/PageShell": {
      "types": "./src/primitives/PageShell.tsx",
