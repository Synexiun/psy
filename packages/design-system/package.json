    "./primitives/Card": "./src/primitives/Card.tsx",
    "./primitives/Input": "./src/primitives/Input.tsx",
    "./primitives/Textarea": "./src/primitives/Textarea.tsx",
    "./primitives/Divider": "./src/primitives/Divider.tsx",
    "./primitives/Spinner": "./src/primitives/Spinner.tsx",
    "./primitives/Skeleton": "./src/primitives/Skeleton.tsx",
    "./primitives/Tooltip": "./src/primitives/Tooltip.tsx",
    "./primitives/Badge": "./src/primitives/Badge.tsx",
    "./primitives/ProgressRing": "./src/primitives/ProgressRing.tsx",
    "./primitives/Sparkline": "./src/primitives/Sparkline.tsx",
