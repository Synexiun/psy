{
  "name": "@disciplineos/web-crisis",
  "version": "0.0.0",
  "private": true,
  "description": "Static crisis surface. 99.99% SLO. No auth. No runtime dependencies on the API. Serves the hotline directory and local emergency numbers from the bundled @disciplineos/safety-directory.",
  "scripts": {
    "dev": "next dev --port 3050",
    "build": "next build",
    "start": "next start --port 3050",
    "export": "next build",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:offline": "playwright test tests/offline"
  },
  "dependencies": {
    "@disciplineos/design-system": "workspace:*",
    "@disciplineos/safety-directory": "workspace:*",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.11.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "vitest": "^2.1.0"
  }
}
