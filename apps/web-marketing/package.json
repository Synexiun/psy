{
  "name": "@disciplineos/web-marketing",
  "version": "0.0.0",
  "private": true,
  "description": "Public marketing site. 4 locales (en, fr, ar, fa). Static-rendered at the edge, no auth, no PHI.",
  "scripts": {
    "dev": "next dev --port 3010",
    "build": "next build",
    "start": "next start --port 3010",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@disciplineos/design-system": "workspace:*",
    "@disciplineos/i18n-catalog": "workspace:*",
    "next": "^15.0.0",
    "next-intl": "^3.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.11.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "vitest": "^2.1.0"
  }
}
