{
  "name": "@disciplineos/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild --clean",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
